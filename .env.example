# Database (set by Fly.io when you attach a Postgres cluster)
DATABASE_URL=postgresql://user:password@localhost:5432/gleamnsip

# Flask secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-random-string

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Anthropic API key (optional — users can also set per-account in Settings)
ANTHROPIC_API_KEY=sk-ant-...
